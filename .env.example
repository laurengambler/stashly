# Copy this file to .env and fill in real values.
# All keys MUST start with VITE_ to be exposed to the browser by Vite.

# Supabase — find these in your Supabase dashboard under Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# PostHog — Project Settings → Project API Key in your PostHog dashboard
# Use https://us.i.posthog.com for US Cloud or https://eu.i.posthog.com for EU.
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxx
VITE_POSTHOG_HOST=https://us.i.posthog.com
